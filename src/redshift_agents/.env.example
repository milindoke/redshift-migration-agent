# AWS Region (agents can operate on clusters in any region)
AWS_REGION=us-east-2

# DynamoDB table for cluster locking
DYNAMODB_LOCK_TABLE=redshift_modernization_locks

# Bedrock AgentCore agent IDs (set after deployment)
ASSESSMENT_AGENT_ID=redshift-assessment-subagent
ARCHITECTURE_AGENT_ID=redshift-architecture-subagent
EXECUTION_AGENT_ID=redshift-execution-subagent

# Optional: AWS Account ID (auto-detected via STS if not set)
# AWS_ACCOUNT_ID=123456789012
