# AWS Region (agents can operate on clusters in any region)
AWS_REGION=us-east-2

# DynamoDB table for cluster locking
DYNAMODB_LOCK_TABLE=redshift_modernization_locks

# Bedrock Agent IDs (set after CDK deployment — see CDK outputs)
ORCHESTRATOR_AGENT_ID=<from CDK output OrchestratorAgentId>
ORCHESTRATOR_AGENT_ALIAS_ID=<from CDK output OrchestratorAliasId>

# Cognito authentication (set after CDK deployment — see CDK outputs)
COGNITO_USER_POOL_ID=<from CDK output CognitoUserPoolId>
COGNITO_APP_CLIENT_ID=<from CDK output CognitoAppClientId>
COGNITO_IDENTITY_POOL_ID=<from CDK output CognitoIdentityPoolId>

# Optional: AWS Account ID (auto-detected via STS if not set)
# AWS_ACCOUNT_ID=123456789012
