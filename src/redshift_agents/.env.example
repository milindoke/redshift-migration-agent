# Environment variables for local Docker testing
# Copy this file to .env and fill in your values

# AWS Credentials (Service Account - 497316421912)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here
AWS_REGION=us-east-2

# ATX MCP Server Configuration (provided by SA)
MCP_WORKSPACE_ID=your_workspace_id_here
MCP_AUTH_TOKEN=your_auth_token_here
MCP_BINARY_LOCATION=/path/to/eg_agentic_mcp_server

# Agent Configuration
ORCHESTRATOR_PORT=8080
ASSESSMENT_PORT=8081
SCORING_PORT=8082
ARCHITECTURE_PORT=8083
EXECUTION_PORT=8084

# Storage
STORAGE_BASE_DIR=./storage
