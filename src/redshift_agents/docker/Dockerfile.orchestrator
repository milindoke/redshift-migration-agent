# Dockerfile for Redshift Modernization Orchestrator
# For deployment to Amazon Bedrock AgentCore

FROM public.ecr.aws/docker/library/python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Create working directory
WORKDIR /app

# Copy and install SDK wheel files first
COPY sdk/*.whl /tmp/sdk/
RUN pip install --no-cache-dir /tmp/sdk/*.whl

# Copy requirements and install remaining dependencies
COPY src/redshift_agents/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt || true

# Copy application code
COPY src/redshift_agents/orchestrator/ /app/orchestrator/
COPY src/redshift_agents/tools/ /app/tools/
COPY src/redshift_agents/__init__.py /app/

# Set environment variables
ENV PYTHONPATH=/app
ENV AWS_DEFAULT_REGION=us-east-2
ENV STORAGE_DIR=/tmp/orchestrator

# Expose port for AgentCore
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/ping')" || exit 1

# Entry point: Start AgentRuntimeServer with orchestrator factory
CMD ["python3", "-m", "eg_platform_base_agent.orchestrator_cli", \
     "--agent-factory", "orchestrator.orchestrator:create_orchestrator", \
     "--storage-dir", "/tmp/orchestrator", \
     "--host", "0.0.0.0", \
     "--port", "8080"]
